<%- include('../layout', {
    title: '订单详情',
    currentPage: 'orders',
    user: user
}) %>

<div class="card">
    <div class="card-header">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0">订单详情</h5>
            <a href="/admin/orders" class="btn btn-admin btn-admin-secondary btn-sm">
                <i class="fas fa-arrow-left"></i> 返回列表
            </a>
        </div>
    </div>
    <div class="card-body">
        <!-- 订单信息 -->
        <div class="row mb-4">
            <div class="col-md-6">
                <h6>订单基本信息</h6>
                <table class="table table-sm table-borderless">
                    <tr>
                        <td width="120">订单号：</td>
                        <td><strong><%= order.order_number %></strong></td>
                    </tr>
                    <tr>
                        <td>订单状态：</td>
                        <td>
                            <span class="status-badge status-<%= order.status %>">
                                <%= order.status === 'pending' ? '待处理' :
                                   order.status === 'processing' ? '处理中' :
                                   order.status === 'completed' ? '已完成' :
                                   order.status === 'cancelled' ? '已取消' : order.status %>
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <td>创建时间：</td>
                        <td><%= new Date(order.created_at).toLocaleString('zh-CN') %></td>
                    </tr>
                    <tr>
                        <td>更新时间：</td>
                        <td><%= new Date(order.updated_at).toLocaleString('zh-CN') %></td>
                    </tr>
                </table>
            </div>
            <div class="col-md-6">
                <h6>客户信息</h6>
                <table class="table table-sm table-borderless">
                    <tr>
                        <td width="120">用户名：</td>
                        <td><%= order.username %></td>
                    </tr>
                    <tr>
                        <td>邮箱：</td>
                        <td><%= order.email %></td>
                    </tr>
                    <tr>
                        <td>电话：</td>
                        <td><%= order.phone || '未填写' %></td>
                    </tr>
                    <tr>
                        <td>收货地址：</td>
                        <td><%= order.shipping_address || '未填写' %></td>
                    </tr>
                </table>
            </div>
        </div>

        <!-- 订单商品 -->
        <h6>订单商品</h6>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>商品</th>
                        <th>单价</th>
                        <th>数量</th>
                        <th>小计</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (orderItems && orderItems.length > 0) { %>
                        <% orderItems.forEach(item => { %>
                            <tr>
                                <td>
                                    <% if (item.image_url) { %>
                                        <img src="<%= item.image_url %>" alt="<%= item.name %>" style="width: 50px; height: 50px; object-fit: cover; margin-right: 10px;" class="rounded">
                                    <% } %>
                                    <%= item.name %>
                                </td>
                                <td>¥<%= item.price.toFixed(2) %></td>
                                <td><%= item.quantity %></td>
                                <td>¥<%= (item.price * item.quantity).toFixed(2) %></td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="text-center text-muted">暂无商品</td>
                        </tr>
                    <% } %>
                </tbody>
                <tfoot>
                    <tr>
                        <th colspan="3" class="text-end">订单总额：</th>
                        <th><strong>¥<%= order.total_amount.toFixed(2) %></strong></th>
                    </tr>
                </tfoot>
            </table>
        </div>

        <!-- 订单状态更新 -->
        <div class="mt-4">
            <h6>更新订单状态</h6>
            <form id="statusForm" class="d-flex gap-2">
                <select name="status" class="form-select" style="width: auto;">
                    <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>待处理</option>
                    <option value="processing" <%= order.status === 'processing' ? 'selected' : '' %>>处理中</option>
                    <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>已完成</option>
                    <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>已取消</option>
                </select>
                <button type="submit" class="btn btn-admin btn-admin-primary">
                    <i class="fas fa-save"></i> 更新状态
                </button>
            </form>
        </div>
    </div>
</div>

<script>
document.getElementById('statusForm').addEventListener('submit', async function(e) {
    e.preventDefault();

    const status = this.querySelector('select[name="status"]').value;

    try {
        const response = await fetch('/admin/orders/<%= order.id %>/status', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ status })
        });

        const result = await response.json();

        if (result.success) {
            alert('订单状态已更新');
            location.reload();
        } else {
            alert('更新失败：' + result.message);
        }
    } catch (error) {
        console.error('更新订单状态失败:', error);
        alert('网络错误，请稍后重试');
    }
});
</script>
