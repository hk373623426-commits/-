<%
// list-body.ejs - 订单列表主体内容
%>
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">订单列表</h5>
        <div>
            <span class="me-3">
                <span class="text-muted">总计：</span>
                <strong><%= orders.length %></strong> 条订单
            </span>
        </div>
    </div>
    <div class="card-body">
        <!-- 状态筛选 -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="btn-group" role="group">
                    <a href="/admin/orders?status=all&page=1" class="btn btn-admin <%= status === 'all' ? 'btn-admin-primary' : 'btn-outline-secondary' %>">
                        全部 (<%= statusStats.find(s => true)?.count || 0 %>)
                    </a>
                    <a href="/admin/orders?status=pending&page=1" class="btn btn-admin <%= status === 'pending' ? 'btn-admin-primary' : 'btn-outline-secondary' %>">
                        待处理 (<%= statusStats.find(s => s.status === 'pending')?.count || 0 %>)
                    </a>
                    <a href="/admin/orders?status=processing&page=1" class="btn btn-admin <%= status === 'processing' ? 'btn-admin-primary' : 'btn-outline-secondary' %>">
                        处理中 (<%= statusStats.find(s => s.status === 'processing')?.count || 0 %>)
                    </a>
                    <a href="/admin/orders?status=completed&page=1" class="btn btn-admin <%= status === 'completed' ? 'btn-admin-primary' : 'btn-outline-secondary' %>">
                        已完成 (<%= statusStats.find(s => s.status === 'completed')?.count || 0 %>)
                    </a>
                    <a href="/admin/orders?status=cancelled&page=1" class="btn btn-admin <%= status === 'cancelled' ? 'btn-admin-primary' : 'btn-outline-secondary' %>">
                        已取消 (<%= statusStats.find(s => s.status === 'cancelled')?.count || 0 %>)
                    </a>
                </div>
            </div>
        </div>

        <!-- 订单表格 -->
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>订单号</th>
                        <th>客户</th>
                        <th>金额</th>
                        <th>状态</th>
                        <th>创建时间</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (orders && orders.length > 0) { %>
                        <% orders.forEach(order => { %>
                            <tr>
                                <td><%= order.order_number %></td>
                                <td>
                                    <%= order.username %><br>
                                    <small class="text-muted"><%= order.email %></small>
                                </td>
                                <td>
                                    <strong>¥<%= order.total_amount.toFixed(2) %></strong>
                                </td>
                                <td>
                                    <span class="status-badge status-<%= order.status %>">
                                        <%= order.status === 'pending' ? '待处理' :
                                           order.status === 'processing' ? '处理中' :
                                           order.status === 'completed' ? '已完成' :
                                           order.status === 'cancelled' ? '已取消' : order.status %>
                                    </span>
                                </td>
                                <td><%= new Date(order.created_at).toLocaleString('zh-CN') %></td>
                                <td>
                                    <a href="/admin/orders/<%= order.id %>" class="btn btn-admin btn-admin-primary btn-sm">
                                        <i class="fas fa-eye"></i> 详情
                                    </a>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="fas fa-inbox fa-3x mb-3"></i>
                                <p>暂无订单数据</p>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- 分页 -->
        <% if (totalPages > 1) { %>
            <nav aria-label="订单分页">
                <ul class="pagination justify-content-center">
                    <li class="page-item <%= currentPageNum <= 1 ? 'disabled' : '' %>">
                        <a class="page-link" href="/admin/orders?status=<%= status %>&page=<%= currentPageNum - 1 %>">上一页</a>
                    </li>
                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <li class="page-item <%= currentPageNum === i ? 'active' : '' %>">
                            <a class="page-link" href="/admin/orders?status=<%= status %>&page=<%= i %>"><%= i %></a>
                        </li>
                    <% } %>
                    <li class="page-item <%= currentPageNum >= totalPages ? 'disabled' : '' %>">
                        <a class="page-link" href="/admin/orders?status=<%= status %>&page=<%= currentPageNum + 1 %>">下一页</a>
                    </li>
                </ul>
            </nav>
        <% } %>
    </div>
</div>
