<%- include('layout', {
    title: title || '错误',
    currentPage: '',
    user: user
}) %>

<div class="card">
    <div class="card-body text-center py-5">
        <i class="fas fa-exclamation-triangle fa-4x text-warning mb-4"></i>
        <h3 class="mb-3"><%= title || '服务器错误' %></h3>
        <p class="text-muted mb-4"><%= message || '抱歉，服务器内部错误，请稍后重试' %></p>
        <a href="/admin/dashboard" class="btn btn-admin btn-admin-primary">
            <i class="fas fa-home"></i> 返回仪表盘
        </a>
    </div>
</div>
