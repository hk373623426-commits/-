<%- include('layout', {
    title: '系统设置',
    currentPage: 'settings',
    user: user
}) %>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">网站设置</h5>
            </div>
            <div class="card-body">
                <form id="settingsForm">
                    <div class="mb-3">
                        <label for="siteName" class="form-label">网站名称</label>
                        <input type="text" class="form-control" id="siteName" value="景田矿泉水商城" disabled>
                    </div>
                    <div class="mb-3">
                        <label for="siteDescription" class="form-label">网站描述</label>
                        <textarea class="form-control" id="siteDescription" rows="3" disabled>专注天然矿泉水销售</textarea>
                    </div>
                    <div class="mb-3">
                        <label for="contactEmail" class="form-label">客服邮箱</label>
                        <input type="email" class="form-control" id="contactEmail" value="service@jingtian.com" disabled>
                    </div>
                    <div class="mb-3">
                        <label for="contactPhone" class="form-label">客服电话</label>
                        <input type="tel" class="form-control" id="contactPhone" value="400-888-8888" disabled>
                    </div>
                </form>
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> 系统设置功能开发中，敬请期待。
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">系统信息</h5>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        系统版本
                        <span class="badge bg-primary">v1.0.0</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        数据库
                        <span class="badge bg-success">SQLite</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        Node.js
                        <span class="badge bg-info">v18.x</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        部署环境
                        <span class="badge bg-warning">Vercel</span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">
                <h5 class="mb-0">快速操作</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="/admin/products/new" class="btn btn-admin btn-admin-success">
                        <i class="fas fa-plus"></i> 添加产品
                    </a>
                    <a href="/admin/orders" class="btn btn-admin btn-admin-primary">
                        <i class="fas fa-clipboard-list"></i> 查看订单
                    </a>
                    <a href="/" class="btn btn-admin btn-admin-secondary" target="_blank">
                        <i class="fas fa-external-link-alt"></i> 访问前台
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
