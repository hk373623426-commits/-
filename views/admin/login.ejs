<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>后台登录 - 景田天然矿泉水</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            max-width: 400px;
            width: 100%;
        }
        .admin-icon {
            font-size: 4rem;
            color: #667eea;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card login-card shadow-lg">
                    <div class="card-body text-center p-5">
                        <div class="mb-4">
                            <i class="fas fa-user-shield admin-icon"></i>
                        </div>
                        <h3 class="mb-4">后台管理系统</h3>

                        <% if (typeof message !== 'undefined' && message) { %>
                            <div class="alert alert-<%= message.type || 'info' %>">
                                <%= message.text %>
                            </div>
                        <% } %>

                        <form action="/admin/login" method="POST">
                            <div class="mb-3">
                                <label for="email" class="form-label text-start d-block">邮箱地址</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-envelope"></i>
                                    </span>
                                    <input type="email" class="form-control" id="email" name="email" required
                                           placeholder="请输入管理员邮箱">
                                </div>
                            </div>

                            <div class="mb-4">
                                <label for="password" class="form-label text-start d-block">密码</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-lock"></i>
                                    </span>
                                    <input type="password" class="form-control" id="password" name="password" required
                                           placeholder="请输入密码">
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary w-100">
                                <i class="fas fa-sign-in-alt me-2"></i>登录
                            </button>
                        </form>

                        <div class="mt-4">
                            <a href="/" class="text-muted">
                                <i class="fas fa-arrow-left me-2"></i>返回首页
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
