<%
// list-body.ejs - 产品列表主体内容
%>
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">产品列表</h5>
        <a href="/admin/products/new" class="btn btn-admin btn-admin-success">
            <i class="fas fa-plus"></i> 添加产品
        </a>
    </div>
    <div class="card-body">
        <!-- 产品表格 -->
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>图片</th>
                        <th>名称</th>
                        <th>分类</th>
                        <th>价格</th>
                        <th>库存</th>
                        <th>状态</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (products && products.length > 0) { %>
                        <% products.forEach(product => { %>
                            <tr>
                                <td><%= product.id %></td>
                                <td>
                                    <% if (product.image_url) { %>
                                        <img src="<%= product.image_url %>" alt="<%= product.name %>" style="width: 50px; height: 50px; object-fit: cover;" class="rounded">
                                    <% } else { %>
                                        <div style="width: 50px; height: 50px; background: #e9ecef; display: flex; align-items: center; justify-content: center;" class="rounded">
                                            <i class="fas fa-image text-muted"></i>
                                        </div>
                                    <% } %>
                                </td>
                                <td><strong><%= product.name %></strong></td>
                                <td><%= product.category_name || '未分类' %></td>
                                <td>¥<%= product.price.toFixed(2) %></td>
                                <td><%= product.stock || 0 %></td>
                                <td>
                                    <% if (product.is_active) { %>
                                        <span class="badge bg-success">上架</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary">下架</span>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="/admin/products/<%= product.id %>/edit" class="btn btn-admin btn-admin-primary">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form action="/admin/products/<%= product.id %>/delete" method="POST" style="display: inline;" onsubmit="return confirm('确定要删除这个产品吗？');">
                                            <button type="submit" class="btn btn-outline-danger">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="8" class="text-center text-muted py-5">
                                <i class="fas fa-box-open fa-3x mb-3"></i>
                                <p>暂无产品数据</p>
                                <a href="/admin/products/new" class="btn btn-admin btn-admin-success mt-2">
                                    <i class="fas fa-plus"></i> 添加第一个产品
                                </a>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- 分页 -->
        <% if (totalPages > 1) { %>
            <nav aria-label="产品分页">
                <ul class="pagination justify-content-center">
                    <li class="page-item <%= currentPageNum <= 1 ? 'disabled' : '' %>">
                        <a class="page-link" href="/admin/products?page=<%= currentPageNum - 1 %>">上一页</a>
                    </li>
                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <li class="page-item <%= currentPageNum === i ? 'active' : '' %>">
                            <a class="page-link" href="/admin/products?page=<%= i %>"><%= i %></a>
                        </li>
                    <% } %>
                    <li class="page-item <%= currentPageNum >= totalPages ? 'disabled' : '' %>">
                        <a class="page-link" href="/admin/products?page=<%= currentPageNum + 1 %>">下一页</a>
                    </li>
                </ul>
            </nav>
        <% } %>
    </div>
</div>
