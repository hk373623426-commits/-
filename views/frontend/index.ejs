<%- include('header', {
    title: '首页',
    user: user,
    cartCount: cartCount
}) %>

<!-- 英雄区域 -->
<section class="hero">
    <div class="container">
        <h2>天然矿泉水，健康每一天</h2>
        <p>景田天然矿泉水，源自深层地下水源，富含多种矿物质，为您和家人提供健康饮水保障。</p>
        <a href="/products" class="btn btn-primary">立即选购</a>
    </div>
</section>

<!-- 特色服务 -->
<section class="features py-5 bg-light">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-4 mb-4">
                <div class="feature-icon mb-3">
                    <i class="fas fa-truck fa-3x text-primary"></i>
                </div>
                <h3>快速配送</h3>
                <p>市区内2小时送达，郊区4小时送达，确保您及时用上优质矿泉水。</p>
            </div>
            <div class="col-md-4 mb-4">
                <div class="feature-icon mb-3">
                    <i class="fas fa-shield-alt fa-3x text-primary"></i>
                </div>
                <h3>品质保证</h3>
                <p>每桶水都经过严格检测，符合国家饮用水标准，安全可靠。</p>
            </div>
            <div class="col-md-4 mb-4">
                <div class="feature-icon mb-3">
                    <i class="fas fa-headset fa-3x text-primary"></i>
                </div>
                <h3>专业客服</h3>
                <p>7×24小时在线客服，随时为您解决用水问题。</p>
            </div>
        </div>
    </div>
</section>

<!-- 热门产品 -->
<section class="products-section">
    <div class="section-title">
        <h2>热门产品</h2>
        <p class="text-muted">精选优质矿泉水，满足不同需求</p>
    </div>

    <div class="product-grid">
        <% if (products && products.length > 0) { %>
            <% products.forEach(product => { %>
                <div class="product-card">
                    <div class="product-image">
                        <% if (product.image_url) { %>
                            <img src="<%= product.image_url %>" alt="<%= product.name %>">
                        <% } else { %>
                            <i class="fas fa-water fa-5x text-muted"></i>
                        <% } %>
                    </div>
                    <div class="product-info">
                        <h3><%= product.name %></h3>
                        <p class="text-muted"><%= product.description || '优质天然矿泉水' %></p>
                        <div class="product-price">¥<%= product.price.toFixed(2) %></div>
                        <div class="product-actions">
                            <a href="/products/<%= product.id %>" class="btn btn-sm btn-primary">查看详情</a>
                            <button class="btn btn-sm btn-success add-to-cart"
                                    data-product-id="<%= product.id %>"
                                    data-product-name="<%= product.name %>">
                                <i class="fas fa-cart-plus"></i> 加入购物车
                            </button>
                        </div>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="col-12 text-center">
                <p class="text-muted">暂无产品数据</p>
            </div>
        <% } %>
    </div>

    <div class="text-center mt-4">
        <a href="/products" class="btn btn-primary">查看所有产品</a>
    </div>
</section>

<!-- 为什么选择我们 -->
<section class="why-choose-us py-5 bg-dark text-white">
    <div class="container">
        <div class="section-title">
            <h2 class="text-white">为什么选择景田</h2>
        </div>
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card bg-transparent border-light">
                    <div class="card-body">
                        <h4 class="card-title"><i class="fas fa-mountain me-2"></i>优质水源</h4>
                        <p class="card-text">水源地位于无污染山区，经过多层岩层过滤，富含天然矿物质。</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="card bg-transparent border-light">
                    <div class="card-body">
                        <h4 class="card-title"><i class="fas fa-industry me-2"></i>先进工艺</h4>
                        <p class="card-text">采用国际先进的水处理技术，确保水质纯净安全。</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="card bg-transparent border-light">
                    <div class="card-body">
                        <h4 class="card-title"><i class="fas fa-award me-2"></i>品质认证</h4>
                        <p class="card-text">通过ISO9001质量体系认证，产品质量有保障。</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="card bg-transparent border-light">
                    <div class="card-body">
                        <h4 class="card-title"><i class="fas fa-users me-2"></i>客户至上</h4>
                        <p class="card-text">超过10万家庭的选择，客户满意度达98%。</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 客户评价 -->
<section class="testimonials py-5">
    <div class="container">
        <div class="section-title">
            <h2>客户评价</h2>
        </div>
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="testimonial-card p-4 border rounded">
                    <div class="d-flex align-items-center mb-3">
                        <div class="avatar me-3">
                            <i class="fas fa-user-circle fa-3x text-primary"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">张先生</h5>
                            <small class="text-muted">使用2年</small>
                        </div>
                    </div>
                    <p class="mb-0">"水质很好，配送及时，服务态度也很好，已经用了两年了。"</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="testimonial-card p-4 border rounded">
                    <div class="d-flex align-items-center mb-3">
                        <div class="avatar me-3">
                            <i class="fas fa-user-circle fa-3x text-primary"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">李女士</h5>
                            <small class="text-muted">使用1年</small>
                        </div>
                    </div>
                    <p class="mb-0">"价格实惠，水质纯净，家里老人孩子都爱喝。"</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="testimonial-card p-4 border rounded">
                    <div class="d-flex align-items-center mb-3">
                        <div class="avatar me-3">
                            <i class="fas fa-user-circle fa-3x text-primary"></i>
                        </div>
                        <div>
                            <h5 class="mb-0">王先生</h5>
                            <small class="text-muted">公司采购</small>
                        </div>
                    </div>
                    <p class="mb-0">"为公司采购桶装水，服务专业，发票及时，非常满意。"</p>
                </div>
            </div>
        </div>
    </div>
</section>

<%- include('footer') %>

<script>
// 初始化购物车功能
document.addEventListener('DOMContentLoaded', function() {
    // 更新购物车数量
    fetch('/cart/count')
        .then(response => response.json())
        .then(data => {
            if (data.success && data.count > 0) {
                updateCartCount(data.count);
            }
        })
        .catch(error => console.error('获取购物车数量失败:', error));
});
</script>