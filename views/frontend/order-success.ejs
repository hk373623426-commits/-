<%- include('header', {
    title: '订单提交成功',
    user: null,
    cartCount: 0
}) %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-success">
                <div class="card-header bg-success text-white text-center py-4">
                    <i class="fas fa-check-circle fa-4x mb-2"></i>
                    <h2>订单提交成功！</h2>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-success">
                        <h5><i class="fas fa-info-circle me-2"></i>订单信息</h5>
                        <table class="table table-borderless mb-0">
                            <tr>
                                <td width="120"><strong>订单编号：</strong></td>
                                <td><span class="text-primary"><%= order.order_number %></span></td>
                            </tr>
                            <tr>
                                <td><strong>订单金额：</strong></td>
                                <td><span class="text-danger h4">¥<%= order.total_amount.toFixed(2) %></span></td>
                            </tr>
                            <tr>
                                <td><strong>下单时间：</strong></td>
                                <td><%= new Date(order.created_at).toLocaleString('zh-CN') %></td>
                            </tr>
                        </table>
                    </div>

                    <div class="mb-4">
                        <h5><i class="fas fa-truck me-2"></i>配送信息</h5>
                        <div class="bg-light p-3 rounded">
                            <p class="mb-2"><i class="fas fa-user me-2"></i><strong>收货人：</strong><%= order.customer_name %></p>
                            <p class="mb-2"><i class="fas fa-phone me-2"></i><strong>联系电话：</strong><%= order.customer_phone %></p>
                            <p class="mb-2"><i class="fas fa-map-marker-alt me-2"></i><strong>送货地址：</strong><%= order.delivery_address %></p>
                            <% if (order.delivery_time) { %>
                                <p class="mb-0"><i class="fas fa-clock me-2"></i><strong>配送时间：</strong>
                                    <%= order.delivery_time === 'asap' ? '尽快配送' :
                                        order.delivery_time === 'morning' ? '上午 (8:00-12:00)' :
                                        order.delivery_time === 'afternoon' ? '下午 (12:00-18:00)' :
                                        '晚上 (18:00-20:00)' %>
                                </p>
                            <% } %>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h5><i class="fas fa-box me-2"></i>商品清单</h5>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead class="table-light">
                                    <tr>
                                        <th>商品名称</th>
                                        <th>单价</th>
                                        <th>数量</th>
                                        <th class="text-end">小计</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% order.items.forEach(item => { %>
                                        <tr>
                                            <td><%= item.product_name %></td>
                                            <td>¥<%= item.price.toFixed(2) %></td>
                                            <td>× <%= item.quantity %></td>
                                            <td class="text-end">¥<%= (item.price * item.quantity).toFixed(2) %></td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <th colspan="3" class="text-end">总计：</th>
                                        <th class="text-end text-danger">¥<%= order.total_amount.toFixed(2) %></th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>

                    <div class="alert alert-info">
                        <h6><i class="fas fa-bell me-2"></i>温馨提示</h6>
                        <ul class="mb-0">
                            <li>我们会在 2 小时内联系您确认订单</li>
                            <li>请保持电话畅通，配送员会提前联系您</li>
                            <li>如有问题请致电客服热线：<strong>400-888-8888</strong></li>
                        </ul>
                    </div>

                    <div class="text-center">
                        <a href="/products" class="btn btn-primary btn-lg me-2">
                            <i class="fas fa-water me-2"></i>继续购物
                        </a>
                        <button class="btn btn-outline-secondary btn-lg" onclick="window.print()">
                            <i class="fas fa-print me-2"></i>打印订单
                        </button>
                    </div>
                </div>
            </div>

            <div class="text-center mt-4">
                <p class="text-muted">
                    <a href="/orders/track">查询订单状态</a> |
                    <a href="/">返回首页</a>
                </p>
            </div>
        </div>
    </div>
</div>

<%- include('footer') %>
