<!-- FAQ 常见问题 -->
<section class="faq py-5">
    <div class="container">
        <div class="section-title text-center mb-5">
            <h2>常见问题</h2>
            <p class="text-muted">您可能想知道的问题</p>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="accordion" id="faqAccordion">
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingOne">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                                如何订购桶装水？
                            </button>
                        </h2>
                        <div id="collapseOne" class="accordion-collapse collapse show" aria-labelledby="headingOne" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                您可以通过以下方式订购：
                                <ol class="mb-0">
                                    <li>登录网站，在产品中心选择所需产品后加入购物车结算</li>
                                    <li>拨打客服热线 400-888-8888 电话订购</li>
                                    <li>关注官方微信公众号进行在线下单</li>
                                </ol>
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingTwo">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                                配送范围和时间是怎样的？
                            </button>
                        </h2>
                        <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="headingTwo" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                目前我们主要服务于全国一二线城市市区范围。一般情况下：
                                <ul class="mb-0">
                                    <li>市区内：下单后 2-4 小时送达</li>
                                    <li>郊区：下单后 4-8 小时送达</li>
                                    <li>具体配送时间以客服人员确认为准</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingThree">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                                空桶押金如何收取和退还？
                            </button>
                        </h2>
                        <div id="collapseThree" class="accordion-collapse collapse" aria-labelledby="headingThree" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                <ul class="mb-0">
                                    <li>首次订购需支付桶押金，一般为 50-100 元/桶（视桶型而定）</li>
                                    <li>押金桶可循环使用，退桶时凭完好水桶和押金收据全额退还押金</li>
                                    <li>也可选择购买水桶，购买后无需退还</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingFour">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFour" aria-expanded="false" aria-controls="collapseFour">
                                如何开具发票？
                            </button>
                        </h2>
                        <div id="collapseFour" class="accordion-collapse collapse" aria-labelledby="headingFour" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                您可以在下单时选择需要发票，填写发票抬头和税号等信息。我们提供电子发票和纸质发票两种选择：
                                <ul class="mb-0">
                                    <li>电子发票：订单完成后发送至您的邮箱</li>
                                    <li>纸质发票：随订单配送或邮寄给您</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
function submitForm(event) {
    event.preventDefault();

    const formData = {
        name: document.getElementById('name').value,
        phone: document.getElementById('phone').value,
        email: document.getElementById('email').value,
        subject: document.getElementById('subject').value,
        address: document.getElementById('address').value,
        message: document.getElementById('message').value
    };

    fetch('/contact/submit', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify(formData)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('留言提交成功！我们将尽快与您联系。');
            document.getElementById('contactForm').reset();
        } else {
            alert(data.message || '提交失败，请重试');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('提交失败，请重试');
    });

    return false;
}
</script>
