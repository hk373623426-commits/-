<%- include('header', {
    cartCount: typeof cartCount !== 'undefined' ? cartCount : 0,
    title: title || '页面未找到',
    user: user
}) %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <!-- 404 图标 -->
            <div class="error-icon mb-4">
                <i class="fas fa-exclamation-triangle fa-5x text-warning"></i>
            </div>

            <!-- 404 大字 -->
            <h1 class="display-1 fw-bold text-primary mb-4">404</h1>

            <!-- 错误信息 -->
            <h2 class="mb-4">页面未找到</h2>
            <p class="lead text-muted mb-4">
                抱歉，您访问的页面不存在或已被移除。
            </p>

            <!-- 可能原因 -->
            <div class="alert alert-light border text-start mb-4">
                <strong>可能的原因：</strong>
                <ul class="mb-0 mt-2">
                    <li>网址输入错误</li>
                    <li>页面已被删除或移动</li>
                    <li>您点击了过期的链接</li>
                </ul>
            </div>

            <!-- 操作按钮 -->
            <div class="mt-5">
                <a href="/" class="btn btn-primary btn-lg me-2">
                    <i class="fas fa-home"></i> 返回首页
                </a>
                <a href="/products" class="btn btn-outline-primary btn-lg me-2">
                    <i class="fas fa-water"></i> 浏览产品
                </a>
                <a href="/contact" class="btn btn-outline-secondary btn-lg">
                    <i class="fas fa-phone"></i> 联系我们
                </a>
            </div>

            <!-- 搜索框 -->
            <div class="mt-5">
                <p class="text-muted mb-3">或者搜索您需要的内容</p>
                <form action="/products" method="GET" class="d-inline-flex" style="max-width: 500px;">
                    <input type="text" name="search" class="form-control form-control-lg" placeholder="搜索产品..." required>
                    <button type="submit" class="btn btn-primary btn-lg ms-2">
                        <i class="fas fa-search"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- 热门推荐 -->
<section class="py-5 bg-light mt-5">
    <div class="container">
        <div class="section-title text-center mb-4">
            <h3>热门产品推荐</h3>
        </div>
        <div class="row">
            <% for (let i = 1; i <= 4; i++) { %>
            <div class="col-md-3 col-sm-6 mb-4">
                <div class="product-card bg-white rounded shadow-sm h-100">
                    <div class="product-image text-center py-5 bg-light">
                        <i class="fas fa-bottle-water fa-4x text-muted"></i>
                    </div>
                    <div class="product-info p-3">
                        <h5>景田天然矿泉水 <%= i %>号</h5>
                        <p class="text-muted small">优质天然矿泉水，富含矿物质</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-primary fw-bold">¥<%= (15 + i * 2).toFixed(2) %></span>
                            <a href="/products" class="btn btn-sm btn-primary">查看详情</a>
                        </div>
                    </div>
                </div>
            </div>
            <% } %>
        </div>
    </div>
</section>
