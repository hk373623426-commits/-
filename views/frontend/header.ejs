<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - 景田天然矿泉水</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
</head>
<body>
    <!-- 头部导航 -->
    <header class="header">
        <div class="header-container">
            <div class="logo">
                <i class="fas fa-tint fa-2x"></i>
                <h1>景田<span>天然矿泉水</span></h1>
            </div>

            <button class="menu-toggle d-md-none">
                <i class="fas fa-bars"></i>
            </button>

            <nav>
                <ul class="nav-menu">
                    <li><a href="/"><i class="fas fa-home"></i> 首页</a></li>
                    <li><a href="/products"><i class="fas fa-water"></i> 产品中心</a></li>
                    <li><a href="/about"><i class="fas fa-info-circle"></i> 关于我们</a></li>
                    <li><a href="/contact"><i class="fas fa-phone"></i> 联系我们</a></li>
                    <li><a href="/orders/track"><i class="fas fa-search-location"></i> 订单查询</a></li>
                </ul>
            </nav>

            <div class="user-menu">
                <a href="/cart" class="cart-icon">
                    <i class="fas fa-shopping-cart fa-lg"></i>
                    <% if (typeof cartCount !== 'undefined' && cartCount && cartCount > 0) { %>
                        <span class="cart-count"><%= cartCount %></span>
                    <% } %>
                </a>
            </div>
        </div>
    </header>

    <!-- 主要内容区域 -->
    <main>
        <% if (typeof message !== 'undefined' && message) { %>
            <div class="container mt-3">
                <div class="alert alert-<%= message.type || 'info' %>">
                    <%= message.text %>
                </div>
            </div>
        <% } %>
