<%- include('header', {
    cartCount: typeof cartCount !== 'undefined' ? cartCount : 0,
    title: product.name,
    user: user,
    cartCount: cartCount
}) %>

<div class="container py-5">
    <!-- 面包屑导航 -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">首页</a></li>
            <li class="breadcrumb-item"><a href="/products">产品中心</a></li>
            <li class="breadcrumb-item active"><%= product.name %></li>
        </ol>
    </nav>

    <!-- 产品详情 -->
    <div class="row">
        <!-- 产品图片 -->
        <div class="col-md-6 mb-4">
            <div class="product-detail-image bg-light rounded d-flex align-items-center justify-content-center" style="height: 500px;">
                <% if (product.image_url) { %>
                    <img src="<%= product.image_url %>" alt="<%= product.name %>" class="img-fluid" style="max-height: 450px;">
                <% } else { %>
                    <i class="fas fa-bottle-water fa-8x text-muted"></i>
                <% } %>
            </div>
        </div>

        <!-- 产品信息 -->
        <div class="col-md-6">
            <h1 class="mb-3"><%= product.name %></h1>

            <div class="mb-3">
                <span class="badge bg-primary"><%= product.category_name || '矿泉水' %></span>
                <% if (product.stock > 0) { %>
                    <span class="badge bg-success">有货</span>
                <% } else { %>
                    <span class="badge bg-danger">缺货</span>
                <% } %>
            </div>

            <div class="product-price-large mb-4">
                <span class="price">¥<%= product.price.toFixed(2) %></span>
                <% if (product.original_price) { %>
                    <span class="original-price text-muted text-decoration-line-through">¥<%= product.original_price.toFixed(2) %></span>
                <% } %>
            </div>

            <p class="lead mb-4"><%= product.description || '优质天然矿泉水' %></p>

            <!-- 产品规格 -->
            <div class="product-specs mb-4 p-3 bg-light rounded">
                <h5>产品规格</h5>
                <table class="table table-sm table-borderless mb-0">
                    <tbody>
                        <% if (product.specification) { %>
                        <tr>
                            <td width="120"><strong>规格</strong></td>
                            <td><%= product.specification %></td>
                        </tr>
                        <% } %>
                        <% if (product.unit) { %>
                        <tr>
                            <td><strong>单位</strong></td>
                            <td><%= product.unit %></td>
                        </tr>
                        <% } %>
                        <% if (product.minerals) { %>
                        <tr>
                            <td><strong>矿物质含量</strong></td>
                            <td><%= product.minerals %></td>
                        </tr>
                        <% } %>
                        <tr>
                            <td><strong>保质期</strong></td>
                            <td><%= product.shelf_life || '12 个月' %></td>
                        </tr>
                        <tr>
                            <td><strong>储存方式</strong></td>
                            <td>置于阴凉干燥处</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- 购买操作 -->
            <div class="product-actions mb-4">
                <div class="input-group mb-3" style="max-width: 300px;">
                    <button class="btn btn-outline-secondary" type="button" onclick="decreaseQuantity()">-</button>
                    <input type="number" class="form-control text-center" id="quantity" value="1" min="1" max="<%= product.stock || 99 %>" style="width: 80px;">
                    <button class="btn btn-outline-secondary" type="button" onclick="increaseQuantity()">+</button>
                </div>

                <button class="btn btn-primary btn-lg me-2" onclick="addToCart()">
                    <i class="fas fa-cart-plus"></i> 加入购物车
                </button>
                <button class="btn btn-success btn-lg" onclick="buyNow()">
                    <i class="fas fa-bolt"></i> 立即购买
                </button>
            </div>

            <!-- 服务承诺 -->
            <div class="product-services p-3 border rounded">
                <div class="row">
                    <div class="col-4 text-center">
                        <i class="fas fa-truck text-primary fa-2x mb-2"></i>
                        <p class="small mb-0">快速配送</p>
                    </div>
                    <div class="col-4 text-center">
                        <i class="fas fa-shield-alt text-primary fa-2x mb-2"></i>
                        <p class="small mb-0">品质保证</p>
                    </div>
                    <div class="col-4 text-center">
                        <i class="fas fa-undo text-primary fa-2x mb-2"></i>
                        <p class="small mb-0">无忧退换</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 产品详情标签页 -->
    <div class="row mt-5">
        <div class="col-12">
            <ul class="nav nav-tabs" id="productTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="detail-tab" data-bs-toggle="tab" data-bs-target="#detail" type="button" role="tab">产品详情</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="params-tab" data-bs-toggle="tab" data-bs-target="#params" type="button" role="tab">参数规格</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews" type="button" role="tab">用户评价</button>
                </li>
            </ul>
            <div class="tab-content p-4 border border-top-0 rounded-bottom" id="productTabContent">
                <div class="tab-pane fade show active" id="detail" role="tabpanel">
                    <div class="product-detail-content">
                        <%- product.detail || '<p class="text-muted">暂无详细信息</p>' %>
                    </div>
                </div>
                <div class="tab-pane fade" id="params" role="tabpanel">
                    <table class="table table-striped">
                        <tbody>
                            <tr>
                                <th width="20%">产品名称</th>
                                <td><%= product.name %></td>
                            </tr>
                            <tr>
                                <th>品牌</th>
                                <td>景田</td>
                            </tr>
                            <tr>
                                <th>规格</th>
                                <td><%= product.specification || '未指定' %></td>
                            </tr>
                            <tr>
                                <th>单位</th>
                                <td><%= product.unit || '桶' %></td>
                            </tr>
                            <tr>
                                <th>保质期</th>
                                <td><%= product.shelf_life || '12 个月' %></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="tab-pane fade" id="reviews" role="tabpanel">
                    <div class="text-center py-5">
                        <i class="fas fa-comments fa-4x text-muted mb-3"></i>
                        <p class="text-muted">暂无用户评价</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 相关产品 -->
    <% if (relatedProducts && relatedProducts.length > 0) { %>
    <div class="row mt-5">
        <div class="col-12">
            <h3 class="mb-4">相关产品</h3>
        </div>
        <% relatedProducts.forEach(p => { %>
            <div class="col-md-3 col-sm-6 mb-4">
                <div class="product-card">
                    <div class="product-image">
                        <% if (p.image_url) { %>
                            <img src="<%= p.image_url %>" alt="<%= p.name %>">
                        <% } else { %>
                            <i class="fas fa-bottle-water fa-4x text-muted"></i>
                        <% } %>
                    </div>
                    <div class="product-info">
                        <h5><%= p.name %></h5>
                        <p class="text-muted small"><%= p.description?.substring(0, 30) || '' %>...</p>
                        <div class="product-price">¥<%= p.price.toFixed(2) %></div>
                        <a href="/products/<%= p.id %>" class="btn btn-sm btn-primary">查看详情</a>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>
    <% } %>
</div>

<script>
function increaseQuantity() {
    const input = document.getElementById('quantity');
    const max = <%= product.stock || 99 %>;
    if (parseInt(input.value) < max) {
        input.value = parseInt(input.value) + 1;
    }
}

function decreaseQuantity() {
    const input = document.getElementById('quantity');
    if (parseInt(input.value) > 1) {
        input.value = parseInt(input.value) - 1;
    }
}

function addToCart() {
    const quantity = document.getElementById('quantity').value;
    fetch('/cart/add', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            product_id: <%= product.id %>,
            quantity: parseInt(quantity)
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('已成功添加到购物车！');
            updateCartCount(data.cartCount);
        } else {
            alert(data.message || '添加失败，请重试');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('添加失败，请重试');
    });
}

function buyNow() {
    const quantity = document.getElementById('quantity').value;
    fetch('/cart/add', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            product_id: <%= product.id %>,
            quantity: parseInt(quantity)
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            window.location.href = '/cart';
        } else {
            alert(data.message || '添加失败，请重试');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('添加失败，请重试');
    });
}
</script>
