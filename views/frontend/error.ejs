<%- include('header', {
    cartCount: typeof cartCount !== 'undefined' ? cartCount : 0,
    title: title || '服务器错误',
    user: user
}) %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <!-- 错误图标 -->
            <div class="error-icon mb-4">
                <i class="fas fa-exclamation-circle fa-5x text-danger"></i>
            </div>

            <!-- 500 大字 -->
            <h1 class="display-1 fw-bold text-danger mb-4">500</h1>

            <!-- 错误信息 -->
            <h2 class="mb-4">服务器内部错误</h2>
            <p class="lead text-muted mb-4">
                <%= message || '抱歉，服务器发生了意外错误，请稍后重试。' %>
            </p>

            <!-- 错误详情（仅开发环境） -->
            <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger text-start mb-4">
                <strong>错误详情：</strong>
                <pre class="mt-2 mb-0"><small><%= error.toString() %></small></pre>
            </div>
            <% } %>

            <!-- 操作按钮 -->
            <div class="mt-5">
                <a href="javascript:location.reload()" class="btn btn-primary btn-lg me-2">
                    <i class="fas fa-redo"></i> 刷新页面
                </a>
                <a href="/" class="btn btn-outline-primary btn-lg me-2">
                    <i class="fas fa-home"></i> 返回首页
                </a>
                <a href="/contact" class="btn btn-outline-secondary btn-lg">
                    <i class="fas fa-phone"></i> 联系我们
                </a>
            </div>

            <!-- 帮助信息 -->
            <div class="mt-5 p-4 bg-light rounded">
                <h5>遇到问题？</h5>
                <p class="text-muted mb-2">如果您持续遇到此问题，请联系我们的客服团队：</p>
                <p class="mb-0">
                    <strong>客服热线：</strong> 400-888-8888<br>
                    <strong>电子邮箱：</strong> service@jingtian.com<br>
                    <strong>服务时间：</strong> 周一至周日 8:00-20:00
                </p>
            </div>
        </div>
    </div>
</div>
