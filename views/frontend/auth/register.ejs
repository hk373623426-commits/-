<%- include('../header', {
    title: '用户注册',
    user: null,
    cartCount: 0
}) %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card">
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0"><i class="fas fa-user-plus me-2"></i>用户注册</h4>
                </div>
                <div class="card-body">
                    <% if (message) { %>
                        <div class="alert alert-<%= message.type %>">
                            <%= message.text %>
                        </div>
                    <% } %>

                    <form action="/auth/register" method="POST" id="registerForm">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="username" class="form-label">用户名 *</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-user"></i>
                                    </span>
                                    <input type="text" class="form-control" id="username" name="username" required
                                           placeholder="请输入用户名" minlength="3" maxlength="20">
                                </div>
                                <div class="form-text">3-20个字符，支持字母、数字、下划线</div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="email" class="form-label">邮箱地址 *</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-envelope"></i>
                                    </span>
                                    <input type="email" class="form-control" id="email" name="email" required
                                           placeholder="请输入邮箱地址">
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="password" class="form-label">密码 *</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-lock"></i>
                                    </span>
                                    <input type="password" class="form-control" id="password" name="password" required
                                           placeholder="请输入密码" minlength="6">
                                </div>
                                <div class="form-text">至少6个字符</div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="confirmPassword" class="form-label">确认密码 *</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-lock"></i>
                                    </span>
                                    <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required
                                           placeholder="请再次输入密码">
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="phone" class="form-label">手机号码</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="fas fa-phone"></i>
                                </span>
                                <input type="tel" class="form-control" id="phone" name="phone"
                                       placeholder="请输入手机号码（选填）" pattern="1[3-9]\d{9}">
                            </div>
                            <div class="form-text">用于订单联系，选填</div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="agreeTerms" name="agreeTerms" required>
                                <label class="form-check-label" for="agreeTerms">
                                    我已阅读并同意 <a href="/terms" target="_blank">服务条款</a> 和 <a href="/privacy" target="_blank">隐私政策</a>
                                </label>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-user-plus me-2"></i>立即注册
                            </button>
                        </div>
                    </form>

                    <div class="mt-4 text-center">
                        <p class="mb-2">已有账号？</p>
                        <a href="/auth/login" class="btn btn-outline-primary">
                            <i class="fas fa-sign-in-alt me-2"></i>立即登录
                        </a>
                    </div>

                    <hr class="my-4">

                    <div class="text-center">
                        <a href="/" class="text-muted">
                            <i class="fas fa-home me-2"></i>返回首页
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('registerForm');
    const password = document.getElementById('password');
    const confirmPassword = document.getElementById('confirmPassword');

    form.addEventListener('submit', function(event) {
        // 验证密码匹配
        if (password.value !== confirmPassword.value) {
            event.preventDefault();
            alert('两次输入的密码不一致，请重新输入');
            confirmPassword.focus();
            return false;
        }

        // 验证密码强度
        if (password.value.length < 6) {
            event.preventDefault();
            alert('密码长度至少6位');
            password.focus();
            return false;
        }

        // 验证用户名格式
        const username = document.getElementById('username');
        const usernameRegex = /^[a-zA-Z0-9_]{3,20}$/;
        if (!usernameRegex.test(username.value)) {
            event.preventDefault();
            alert('用户名格式不正确，只能包含字母、数字、下划线，长度3-20位');
            username.focus();
            return false;
        }

        return true;
    });

    // 实时验证密码匹配
    confirmPassword.addEventListener('input', function() {
        if (password.value !== confirmPassword.value) {
            confirmPassword.classList.add('is-invalid');
        } else {
            confirmPassword.classList.remove('is-invalid');
        }
    });
});
</script>

<%- include('../footer') %>